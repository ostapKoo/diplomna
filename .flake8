[flake8]
# Ігноруємо папку з віртуальним середовищем та інші непотрібні файли
exclude = .git, __pycache__, venv, env, .venv
# Встановлюємо максимальну довжину рядка (стандарт PEP8 - 79, але 120 зручніше для сучасних екранів)
max-line-length = 120
# Ігноруємо деякі некритичні помилки стилю (наприклад, відсутність порожнього рядка в кінці файлу)
ignore = W292, E501